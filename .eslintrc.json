{
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": [
      "error",
      { "vars": "all", "args": "after-used", "ignoreRestSiblings": false }
    ],
    "no-undef": "error",
    "no-unreachable": "error",
    "eqeqeq": ["error", "always"],
    "curly": "error",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-duplicate-imports": "error",
    "no-self-compare": "error"
  }
}
